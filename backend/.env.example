# Backend Environment Configuration
DB_HOST=localhost
DB_PORT=5432
DB_NAME=warehouse_db
DB_USER=warehouse_user
DB_PASSWORD=warehouse_pass
PORT=5000
AI_WORKER_URL=http://localhost:8000
FRONTEND_URL=http://localhost:5173

# Authentication — REQUIRED
# Generate with: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
JWT_SECRET=replace_with_a_long_random_secret_string_at_least_64_chars
JWT_EXPIRY=24h

# Microservice Internal Secret — shared with ai-worker
# Generate with: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
INTERNAL_SECRET=replace_with_a_shared_internal_secret_32_chars_min
